SUPABASE_URL=https://sjiepibqadbdowcizccw.supabase.co
# Get this from Dashboard > Project Settings > API > service_role (secret). Do NOT commit the real value.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
DEFAULT_ACCESS_CLASS=public

# ── MCP server (demo) ──
# Anon (publishable) key — same value as the frontend's VITE_SUPABASE_ANON_KEY.
# The MCP server needs it to call query-knowledge with the caller's user JWT and
# to hit the Supabase auth endpoints.
SUPABASE_ANON_KEY=your-anon-key-here
# Legacy HS256 JWT secret (Dashboard → Settings → API → JWT Settings). Used to
# verify Supabase access tokens locally. Leave unset if the project signs with
# asymmetric keys (ES256/RS256) — those are verified via the JWKS endpoint.
SUPABASE_JWT_SECRET=your-jwt-secret-here
# Public base URL the MCP server is reached at (OAuth issuer = {base}/api/mcp).
MCP_PUBLIC_BASE_URL=http://localhost:8000
# Comma-separated email domains allowed to log in via the MCP server.
MCP_ALLOWED_EMAIL_DOMAINS=kiboventures.com,nzalpha.com
# NOTE: also enable the Google provider in the Supabase dashboard and add
#   http://localhost:8000/api/mcp/supabase-callback
# to the project's allowed redirect URLs.

# ── Gmail connector (multi-tenant; per-firm Workspace + service account) ──
# JSON array, one object per firm. Each firm = a tenant with its own Google
# Workspace + service account authorized for domain-wide delegation. SA keys
# live here (env/secret), never in the database. mailboxes is the explicit list
# of mailboxes to impersonate for that firm.
#   GMAIL_FIRMS=[{"tenant_id":"<uuid>","sa_key_b64":"<base64 SA JSON>","mailboxes":["a@firm.com","b@firm.com"]}]
GMAIL_FIRMS=
# First-run backfill window (days) for recurrent per-mailbox sync.
GMAIL_BACKFILL_DAYS=7

# ── Notes connector (multi-tenant; meeting notes from a source Supabase project) ──
# JSON array, one object per firm. Each firm = a tenant whose meeting notes live
# in a *source* Supabase project, read over a direct Postgres connection using a
# dedicated least-privilege role (forest_notes_reader: SELECT on the 3 source
# tables only). The DSN (incl. role password) is the only source credential and
# lives here, never in the DB. Use the Supabase "Session pooler" connection
# string with the role username, e.g.
#   forest_notes_reader.<source_project_ref>@aws-0-<region>.pooler.supabase.com
#   NOTES_FIRMS=[{"tenant_id":"<uuid>","source_dsn":"postgresql://forest_notes_reader.<ref>:<pw>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require"}]
NOTES_FIRMS=
# Single-firm convenience (used when NOTES_FIRMS is empty):
# NOTES_SOURCE_DSN=postgresql://forest_notes_reader.<ref>:<pw>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require
# NOTES_DEFAULT_TENANT_ID=<uuid>

# ── Affinidad connector (Kibo's in-house CRM) ──
# Reads the platform CRM's Supabase Postgres directly via a dedicated
# least-privilege role (forest_crm_reader: SELECT on entities, entity_edges,
# entity_emails, crm_lists, crm_list_stages, crm_list_entries, crm_list_fields,
# crm_notes, crm_note_links, events, event_participants). Affinidad is
# single-tenant, so attach Kibo's tenant id on the memory side. Use the Supabase
# Session pooler host (aws-1, not aws-0). The DSN (incl. role password) lives here,
# never in the DB.
# AFFINIDAD_SOURCE_DSN=postgresql://forest_crm_reader.<ref>:<pw>@aws-1-<region>.pooler.supabase.com:5432/postgres?sslmode=require
# AFFINIDAD_DEFAULT_TENANT_ID=<uuid>
# Multi-firm form (used when set; overrides the single-firm vars above):
# AFFINIDAD_FIRMS=[{"tenant_id":"<uuid>","source_dsn":"postgresql://forest_crm_reader.<ref>:<pw>@aws-1-<region>.pooler.supabase.com:5432/postgres?sslmode=require"}]
# Cap on events fetched per run (the large table); raise/stage for full backfill.
# AFFINIDAD_MAX_RESULTS=50000
