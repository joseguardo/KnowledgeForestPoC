SUPABASE_URL=https://sjiepibqadbdowcizccw.supabase.co
# Get this from Dashboard > Project Settings > API > service_role (secret). Do NOT commit the real value.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
DEFAULT_ACCESS_CLASS=public

# ── Gmail connector (multi-tenant; per-firm Workspace + service account) ──
# JSON array, one object per firm. Each firm = a tenant with its own Google
# Workspace + service account authorized for domain-wide delegation. SA keys
# live here (env/secret), never in the database. mailboxes is the explicit list
# of mailboxes to impersonate for that firm.
#   GMAIL_FIRMS=[{"tenant_id":"<uuid>","sa_key_b64":"<base64 SA JSON>","mailboxes":["a@firm.com","b@firm.com"]}]
GMAIL_FIRMS=
# First-run backfill window (days) for recurrent per-mailbox sync.
GMAIL_BACKFILL_DAYS=7
