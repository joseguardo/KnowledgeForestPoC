SUPABASE_URL=https://sjiepibqadbdowcizccw.supabase.co
# Get this from Dashboard > Project Settings > API > service_role (secret). Do NOT commit the real value.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
DEFAULT_ACCESS_CLASS=public

# ── Gmail connector (multi-tenant; per-firm Workspace + service account) ──
# JSON array, one object per firm. Each firm = a tenant with its own Google
# Workspace + service account authorized for domain-wide delegation. SA keys
# live here (env/secret), never in the database. mailboxes is the explicit list
# of mailboxes to impersonate for that firm.
#   GMAIL_FIRMS=[{"tenant_id":"<uuid>","sa_key_b64":"<base64 SA JSON>","mailboxes":["a@firm.com","b@firm.com"]}]
GMAIL_FIRMS=
# First-run backfill window (days) for recurrent per-mailbox sync.
GMAIL_BACKFILL_DAYS=7

# ── Notes connector (multi-tenant; meeting notes from a source Supabase project) ──
# JSON array, one object per firm. Each firm = a tenant whose meeting notes live
# in a *source* Supabase project, read over a direct Postgres connection using a
# dedicated least-privilege role (forest_notes_reader: SELECT on the 3 source
# tables only). The DSN (incl. role password) is the only source credential and
# lives here, never in the DB. Use the Supabase "Session pooler" connection
# string with the role username, e.g.
#   forest_notes_reader.<source_project_ref>@aws-0-<region>.pooler.supabase.com
#   NOTES_FIRMS=[{"tenant_id":"<uuid>","source_dsn":"postgresql://forest_notes_reader.<ref>:<pw>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require"}]
NOTES_FIRMS=
# Single-firm convenience (used when NOTES_FIRMS is empty):
# NOTES_SOURCE_DSN=postgresql://forest_notes_reader.<ref>:<pw>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require
# NOTES_DEFAULT_TENANT_ID=<uuid>
